{
  "default_source": "selfstudys",
  "default_dataset": "jee",
  "sources": {
    "selfstudys": {
      "enabled": true,
      "datasets": {
        "jee": {
          "sitemap_url": "https://www.selfstudys.com/sitemaps/jee.xml",
          "fetch": {
            "delay_seconds": 1.0,
            "timeout_seconds": 20,
            "max_retries": 2
          },
          "chunking": {
            "chunk_chars": 450,
            "overlap": 70
          },
          "top_k": 3
        }
      }
    }
  }
}
